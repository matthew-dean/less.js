{
  "compilerOptions": {
    "noEmit": true,
    "moduleResolution": "node",
    "rootDir": ".",
    "allowJs": true,
    "checkJs": true,
    "esModuleInterop": true,
    "importHelpers": true,
    "noImplicitAny": false,
    "strict": false,
    "noImplicitReturns": false,
    "noImplicitThis": false,
    "skipLibCheck": true,
    "target": "ES2015",
    "lib": ["ES2015"]
  },
  "ts-node": {
    "compilerOptions": {
      "rootDir": "."
    }
  },
  "include": [
    "src/less/constants.js",
    "src/less/contexts.js",
    "src/less/logger.js",
    "src/less/types.ts"
  ],
  "exclude": [
    "node_modules",
    "lib",
    "dist",
    "test",
    "benchmark"
  ]
}