#!/usr/bin/env node

/**
 * Less compiler (Jess-powered) — compiles .less files to CSS.
 */

import path from 'path';
import fs from 'fs';
import less from '../lib/index.js';

const args = process.argv.slice(1);
let options = { paths: [], filename: '' };
let input = null;
let output = null;
let silent = false;
let quiet = false;
let verbose = false;

function printUsage() {
  less.lesscHelper.printUsage();
  process.exit(0);
}

function parseArgs() {
  for (let i = 0; i < args.length; i++) {
    const arg = args[i];
    if (arg === '-h' || arg === '--help') {
      printUsage();
    }
    if (arg === '-v' || arg === '--version') {
      console.log(`lessc ${less.version} (Less Compiler) [Jess]`);
      process.exit(0);
    }
    if (arg === '-s' || arg === '--silent') {
      silent = true;
      continue;
    }
    if (arg === '--quiet') {
      quiet = true;
      continue;
    }
    if (arg === '--verbose') {
      verbose = true;
      continue;
    }
    if (arg === '-I' || arg === '--include-path') {
      const match = arg.match(/^-I(.+)$/);
      const paths = (match ? match[1] : args[++i])?.split(/[:;]/) || [];
      options.paths.push(...paths);
      continue;
    }
    if (arg.startsWith('-I')) {
      options.paths.push(...arg.slice(2).split(/[:;]/));
      continue;
    }
    const includeMatch = arg.match(/^--include-path=(.+)$/);
    if (includeMatch) {
      options.paths.push(...includeMatch[1].split(/[:;]/));
      continue;
    }
    if (arg === '--no-color') {
      options.color = false;
      continue;
    }
    if (arg === '-' || arg.endsWith('.less') || arg.endsWith('.css')) {
      if (input === null) {
        input = arg === '-' ? '-' : path.resolve(process.cwd(), arg);
      } else if (output === null) {
        output = path.resolve(process.cwd(), arg);
      }
    }
  }
}

async function run() {
  parseArgs();

  if (!input) {
    console.error('lessc: no input files');
    console.error('');
    printUsage();
  }

  less.logger.addListener({
    info(msg) {
      if (verbose) console.log(msg);
    },
    warn(msg) {
      if (!silent && !quiet) console.warn(msg);
    },
    error(msg) {
      if (!silent) console.error(msg);
    },
  });

  try {
    let result;
    if (input === '-') {
      const data = await new Promise((resolve, reject) => {
        let buf = '';
        process.stdin.setEncoding('utf8');
        process.stdin.on('data', chunk => { buf += chunk; });
        process.stdin.on('end', () => resolve(buf));
        process.stdin.on('error', reject);
      });
      result = await less.render(data, { ...options, filename: 'input.less' });
    } else {
      options.filename = input;
      options.paths = [path.dirname(input), ...options.paths];
      result = await less.renderFile(input, options);
    }

    if (output) {
      fs.mkdirSync(path.dirname(output), { recursive: true });
      fs.writeFileSync(output, result.css, 'utf8');
      if (!silent) less.logger.info(`lessc: wrote ${output}`);
    } else {
      process.stdout.write(result.css);
    }
  } catch (err) {
    if (!silent) {
      console.error(err.toString?.() || err.message);
    }
    process.exitCode = 1;
  }
}

run();
